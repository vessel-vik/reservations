{
  "$schema": "https://openapi.vercel.sh/microfrontends.json",
  "applications": {
    "reservations-pos-core": {
      "packageName": "reservations",
      "development": {
        "local": 3000,
        "fallback": "https://reservations-pos-core.vercel.app"
      }
    },
    "reservations-admin-ops": {
      "routing": [
        {
          "group": "adminOps",
          "paths": [
            "/admin/:path*",
            "/api/pos/print-ops/:path*"
          ]
        }
      ]
    },
    "reservations-customer-touchpoints": {
      "routing": [
        {
          "group": "customerTouchpoints",
          "paths": [
            "/pos/receipt/:path*",
            "/pos/receipts/:path*"
          ]
        }
      ]
    }
  }
}
