# Production Environment Variables for Reservation System
# Copy this file to .env.production and fill in your actual values

# Main Restaurant Site URL
NEXT_PUBLIC_MAIN_SITE_URL=https://your-main-restaurant-site.vercel.app

# Appwrite Configuration
NEXT_PUBLIC_ENDPOINT=https://cloud.appwrite.io/v1
PROJECT_ID=your_project_id
APPWRITE_API_KEY=your_api_key
DATABASE_ID=your_database_id
NEXT_PUBLIC_DATABASE_ID=your_database_id
PATIENT_COLLECTION_ID=your_patient_collection_id
APPOINTMENT_COLLECTION_ID=your_appointment_collection_id
BUCKET_ID=your_bucket_id
NEXT_PUBLIC_BUCKET_ID=your_bucket_id
API_KEY=your_server_api_key
MENU_ITEMS_COLLECTION_ID=menu_items
ORDERS_COLLECTION_ID=orders
CATEGORIES_COLLECTION_ID=categories
DELETED_ORDERS_LOG_COLLECTION_ID=deleted_orders_log
CASH_VERIFICATIONS_COLLECTION_ID=cash_verifications
NEXT_PUBLIC_CASH_VERIFICATIONS_COLLECTION_ID=cash_verifications
INDIVIDUAL_UNITS_COLLECTION_ID=individual_units

# Pinecone (optional — bottle similarity when barcode damaged)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
PINECONE_DIMENSIONS=384

# EmailJS Configuration
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_9q14lw5
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_reservation
NEXT_PUBLIC_EMAILJS_CONFIRMATION_TEMPLATE_ID=template_oxo9v3d
NEXT_PUBLIC_EMAILJS_ADMIN_TEMPLATE_ID=template_zxc4lem
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=zsP1UMPiRDwHjuv1x

# Admin Configuration
NEXT_PUBLIC_ADMIN_PASSKEY=111111

# Africa's Talking SMS (optional)
AFRICASTALKING_USERNAME=your_username
AFRICASTALKING_API_KEY=your_api_key
AFRICASTALKING_FROM=your_shortcode