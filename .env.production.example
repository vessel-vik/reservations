# Production Environment Variables for Reservation System
# Copy this file to .env.production and fill in your actual values

# Main Restaurant Site URL
NEXT_PUBLIC_MAIN_SITE_URL=https://your-main-restaurant-site.vercel.app

# Appwrite Configuration
NEXT_PUBLIC_ENDPOINT=https://cloud.appwrite.io/v1
# Server + scripts (never exposed to the browser)
PROJECT_ID=your_project_id
# Required for client-side Appwrite (Realtime, SDK). Must match PROJECT_ID.
NEXT_PUBLIC_PROJECT_ID=your_project_id
APPWRITE_API_KEY=your_api_key
DATABASE_ID=your_database_id
NEXT_PUBLIC_DATABASE_ID=your_database_id
PATIENT_COLLECTION_ID=your_patient_collection_id
APPOINTMENT_COLLECTION_ID=your_appointment_collection_id
BUCKET_ID=your_bucket_id
NEXT_PUBLIC_BUCKET_ID=your_bucket_id
API_KEY=your_server_api_key
MENU_ITEMS_COLLECTION_ID=menu_items
# Browser Realtime (POS + admin) — must match the server collection IDs above.
NEXT_PUBLIC_MENU_ITEMS_COLLECTION_ID=menu_items
ORDERS_COLLECTION_ID=orders
NEXT_PUBLIC_ORDERS_COLLECTION_ID=orders
# In Appwrite: add string attribute `businessId` on menu_items for Clerk org scoping. Without it, writes retry without the field (see server logs).
CATEGORIES_COLLECTION_ID=categories
DELETED_ORDERS_LOG_COLLECTION_ID=deleted_orders_log
CASH_VERIFICATIONS_COLLECTION_ID=cash_verifications
NEXT_PUBLIC_CASH_VERIFICATIONS_COLLECTION_ID=cash_verifications
INDIVIDUAL_UNITS_COLLECTION_ID=individual_units
PRINT_JOBS_COLLECTION_ID=print_jobs
NEXT_PUBLIC_PRINT_JOBS_COLLECTION_ID=print_jobs
PRINT_AUDIT_ENTRIES_COLLECTION_ID=print_audit_entries
PRINT_TERMINAL_CONTROLS_COLLECTION_ID=print_terminal_controls
PRINT_OPS_INCIDENTS_COLLECTION_ID=print_ops_incidents
PAYMENT_SETTLEMENT_JOBS_COLLECTION_ID=payment_settlement_jobs
PAYMENT_IDEMPOTENCY_COLLECTION_ID=payment_idempotency
PAYMENT_LEDGER_COLLECTION_ID=payment_ledger
SETTLEMENT_WORKER_TOKEN=replace-with-strong-random-token
PAYMENT_RETENTION_DAYS=365
PAYMENT_IDEMPOTENCY_TTL_HOURS=168
SETTLEMENT_JOB_MAX_ATTEMPTS=4
SETTLEMENT_RETRY_BASE_SECONDS=10
WORKER_JENGA_RECONCILE_EVERY_LOOPS=20
WORKER_JENGA_DRIFT_CHECK_EVERY_LOOPS=40
JENGA_DRIFT_SLA_MINUTES=5

# Jenga (Equity Bank) paybill integration
JENGA_ENV=uat
JENGA_BASE_URL=https://uat.finserve.africa
JENGA_API_KEY=
JENGA_MERCHANT_CODE=
JENGA_CONSUMER_SECRET=
JENGA_PRIVATE_KEY=
JENGA_PRIVATE_KEY_PATH=
JENGA_CALLBACK_USERNAME=
JENGA_CALLBACK_PASSWORD=
JENGA_CALLBACK_USERNAME_NEXT=
JENGA_CALLBACK_PASSWORD_NEXT=
JENGA_CALLBACK_BUSINESS_ID=
JENGA_CALLBACK_IP_ALLOWLIST=
JENGA_CALLBACK_REPLAY_WINDOW_MINUTES=30

# Canary rollout controls for bank paybill in /api/payments/settle
BANK_PAYBILL_ROLLOUT_ENABLED=true
BANK_PAYBILL_CANARY_BUSINESS_IDS=
BANK_PAYBILL_CANARY_TERMINAL_IDS=
BANK_PAYBILL_CANARY_REQUIRE_TERMINAL=true

# Pinecone (optional — bottle similarity when barcode damaged)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
PINECONE_DIMENSIONS=384

# EmailJS Configuration
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_9q14lw5
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_reservation
NEXT_PUBLIC_EMAILJS_CONFIRMATION_TEMPLATE_ID=template_oxo9v3d
NEXT_PUBLIC_EMAILJS_ADMIN_TEMPLATE_ID=template_zxc4lem
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=zsP1UMPiRDwHjuv1x

# Receipt / Paybill details (shown in digital + thermal receipts)
NEXT_PUBLIC_RECEIPT_PAYBILL_NUMBER=247247
NEXT_PUBLIC_RECEIPT_PAYBILL_ACCOUNT=555045
NEXT_PUBLIC_RECEIPT_PAYBILL_ACCOUNT_NAME=AMTOPM LOUNGE
NEXT_PUBLIC_RECEIPT_EQUITY_BUSINESS_NUMBER=555045

# Admin Configuration
NEXT_PUBLIC_ADMIN_PASSKEY=111111

# Africa's Talking SMS (optional)
AFRICASTALKING_USERNAME=your_username
AFRICASTALKING_API_KEY=your_api_key
AFRICASTALKING_FROM=your_shortcode

# Central POS waiter PIN mode (shared CHINAMI/Windows station)
NEXT_PUBLIC_CENTRAL_POS_MODE_ENABLED=false
NEXT_PUBLIC_CENTRAL_POS_AUTOLOCK_MS=180000
NEXT_PUBLIC_PRINT_PARALLEL_MODE_ENABLED=false
NEXT_PUBLIC_TABLET_QUEUE_ONLY=true
STAFF_PASSKEYS_COLLECTION_ID=staff_passkeys
STAFF_PASSKEYS_JSON=[]
STAFF_PASSKEY_PEPPER=replace-with-strong-random-secret
STAFF_PASSKEYS_SEED_JSON=[]
STAFF_PASSKEYS_BUSINESS_ID=

# CHINAMI-54SUB2J known USB profile
NEXT_PUBLIC_PRINTER_VENDOR_ID=0x0cf3
NEXT_PUBLIC_PRINTER_PRODUCT_ID=0xe003